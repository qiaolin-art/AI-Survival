.role-card-wrap {
  background: #141414;
  border: 2rpx solid #2a2a2a;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 30rpx 0;
}

.role-header {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.role-emoji {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.role-title-wrap {
  display: flex;
  flex-direction: column;
}

.role-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #e0e0e0;
  margin-bottom: 4rpx;
}

.role-key {
  font-size: 22rpx;
  color: #555;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.role-persona {
  font-size: 28rpx;
  color: #999;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.role-fate {
  border-top: 1rpx solid #2a2a2a;
  padding-top: 24rpx;
}

.fate-item {
  margin-bottom: 20rpx;
}

.fate-item:last-child {
  margin-bottom: 0;
}

.fate-label {
  display: block;
  font-size: 22rpx;
  color: #555;
  margin-bottom: 6rpx;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.fate-text {
  font-size: 28rpx;
  color: #aaa;
  line-height: 1.5;
}

.fate-text.death {
  color: #e74c3c;
}
