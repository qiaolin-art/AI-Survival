.home-page {
  position: relative;
  min-height: 100vh;
  background: #0a0a0a;
  overflow: hidden;
}

.bg-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 30% 0%, rgba(231, 76, 60, 0.06) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 100%, rgba(99, 110, 255, 0.06) 0%, transparent 50%);
}

.content {
  position: relative;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding: 120rpx 40rpx 80rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.header-title {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #e0e0e0;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
}

.header-sub {
  display: block;
  font-size: 26rpx;
  color: #666;
  letter-spacing: 2rpx;
}

/* Quiz Cards */
.quiz-cards {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.quiz-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  border-radius: 20rpx;
  border: 2rpx solid #222;
  background: #111;
  transition: all 0.2s;
}

.quiz-card:active {
  transform: scale(0.98);
  border-color: #333;
}

.quiz1 {
  border-left: 6rpx solid #e74c3c;
}

.quiz2 {
  border-left: 6rpx solid #636eff;
}

/* Card Icon */
.card-icon {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.icon-eye {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.eye-ring-sm {
  position: absolute;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(231, 76, 60, 0.5);
  animation: spin 6s linear infinite;
}

.eye-core-sm {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e74c3c;
  box-shadow: 0 0 16rpx rgba(231, 76, 60, 0.6);
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.icon-briefcase {
  position: relative;
  width: 60rpx;
  height: 50rpx;
}

.briefcase-body {
  position: absolute;
  bottom: 0;
  width: 60rpx;
  height: 40rpx;
  border: 2rpx solid rgba(99, 110, 255, 0.6);
  border-radius: 8rpx;
  background: rgba(99, 110, 255, 0.08);
}

.briefcase-handle {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 28rpx;
  height: 16rpx;
  border: 2rpx solid rgba(99, 110, 255, 0.6);
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
}

.briefcase-pulse {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #636eff;
  box-shadow: 0 0 12rpx rgba(99, 110, 255, 0.6);
  animation: pulse-blue 2s ease-in-out infinite;
}

@keyframes pulse-blue {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.6; }
}

/* Card Body */
.card-body {
  flex: 1;
  min-width: 0;
}

.card-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #888;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  text-transform: uppercase;
}

.quiz1 .card-tag { color: rgba(231, 76, 60, 0.7); }
.quiz2 .card-tag { color: rgba(99, 110, 255, 0.7); }

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #e0e0e0;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.card-desc {
  display: block;
  font-size: 22rpx;
  color: #555;
  letter-spacing: 1rpx;
}

/* Card Arrow */
.card-arrow {
  font-size: 48rpx;
  color: #333;
  margin-left: 16rpx;
  flex-shrink: 0;
}

/* Footer */
.footer {
  text-align: center;
  margin-top: 60rpx;
  padding-bottom: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #444;
  letter-spacing: 1rpx;
}
