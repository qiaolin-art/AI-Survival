<view class="home-page">
  <view class="bg-overlay"></view>

  <view class="content">
    <view class="header">
      <text class="header-title">AI 测试站</text>
      <text class="header-sub">选一个测试，看看你能不能扛住AI</text>
    </view>

    <view class="quiz-cards">
      <!-- Quiz 1: 末日存活 -->
      <view class="quiz-card quiz1" bindtap="onGoQuiz1">
        <view class="card-icon">
          <view class="icon-eye">
            <view class="eye-ring-sm"></view>
            <view class="eye-core-sm"></view>
          </view>
        </view>
        <view class="card-body">
          <text class="card-tag">末日生存</text>
          <text class="card-title">AI控制世界后，你的存活概率</text>
          <text class="card-desc">30个末日场景 · 4大生存维度 · 16种末日角色</text>
        </view>
        <view class="card-arrow">›</view>
      </view>

      <!-- Quiz 2: 职场存活 -->
      <view class="quiz-card quiz2" bindtap="onGoQuiz2">
        <view class="card-icon">
          <view class="icon-briefcase">
            <view class="briefcase-body"></view>
            <view class="briefcase-handle"></view>
            <view class="briefcase-pulse"></view>
          </view>
        </view>
        <view class="card-body">
          <text class="card-tag">职场生存</text>
          <text class="card-title">AI来了，你的工作还能保得住吗</text>
          <text class="card-desc">22个职场场景 · 4大职场维度 · 16种职场角色</text>
        </view>
        <view class="card-arrow">›</view>
      </view>
    </view>

    <view class="footer">
      <text class="footer-text">已有 {{participantCount}} 人参与测试</text>
    </view>
  </view>
</view>
