<view class="result-page">
  <!-- Probability Section -->
  <view class="prob-section">
    <text class="prob-label">你的AI末日存活概率</text>
    <view class="prob-number-wrap">
      <text class="prob-number">{{displayProbability}}</text>
      <text class="prob-percent">%</text>
    </view>
    <view class="tier-title-wrap {{showContent ? 'reveal' : ''}}">
      <text class="tier-title" wx:if="{{tier}}">「{{tier.title}}」</text>
    </view>
  </view>

  <!-- Description -->
  <view class="desc-section {{showContent ? 'reveal' : ''}}">
    <text class="desc-text" wx:if="{{tier}}">{{tier.description}}</text>
  </view>

  <!-- Role Card -->
  <view class="role-section {{showRole ? 'reveal' : ''}}">
    <text class="section-label">你的末日角色</text>
    <role-card role="{{role}}" role-key="{{roleKey}}"></role-card>
  </view>

  <!-- Radar Chart -->
  <view class="radar-section" wx:if="{{showRadar}}">
    <text class="section-label">生存维度分析</text>
    <radar-chart data="{{radarData}}"></radar-chart>
    <view class="radar-legend">
      <view class="legend-item">
        <text class="legend-dot" style="background: #e74c3c"></text>
        <text class="legend-label">{{radarData.R >= 50 ? '冒险' : '谨慎'}} {{radarData.R}}%</text>
      </view>
      <view class="legend-item">
        <text class="legend-dot" style="background: #e67e22"></text>
        <text class="legend-label">{{radarData.S >= 50 ? '群居' : '独狼'}} {{radarData.S}}%</text>
      </view>
      <view class="legend-item">
        <text class="legend-dot" style="background: #f39c12"></text>
        <text class="legend-label">{{radarData.F >= 50 ? '反抗' : '苟活'}} {{radarData.F}}%</text>
      </view>
      <view class="legend-item">
        <text class="legend-dot" style="background: #d35400"></text>
        <text class="legend-label">{{radarData.A >= 50 ? '利他' : '利己'}} {{radarData.A}}%</text>
      </view>
    </view>
  </view>

  <!-- Survival Tip -->
  <view class="tip-section {{showTip ? 'reveal' : ''}}">
    <text class="section-label">末日生存锦囊</text>
    <view class="tip-card" wx:if="{{tier}}">
      <text class="tip-icon">💡</text>
      <text class="tip-text">{{tier.tip}}</text>
    </view>
  </view>

  <!-- Actions -->
  <view class="actions {{showTip ? 'reveal' : ''}}">
    <button class="share-btn" open-type="share">
      分享给好友
    </button>
    <view class="save-btn" bindtap="onGeneratePoster">
      保存海报
    </view>
    <view class="retry-btn" bindtap="onRetry">
      重新测试
    </view>
  </view>

  <!-- Hidden poster canvas -->
  <canvas type="2d" id="posterCanvas" class="poster-canvas"></canvas>
</view>
