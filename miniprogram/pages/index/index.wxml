<view class="index-page">
  <view class="bg-overlay"></view>

  <view class="content">
    <!-- AI Eye -->
    <view class="ai-eye-wrap">
      <view class="ai-eye">
        <view class="eye-ring ring-outer"></view>
        <view class="eye-ring ring-middle"></view>
        <view class="eye-ring ring-inner"></view>
        <view class="eye-core"></view>
      </view>
    </view>

    <!-- Title -->
    <view class="title-section">
      <view class="glitch-text" data-text="AI控制世界后">AI控制世界后</view>
      <view class="main-title">你的存活概率</view>
    </view>

    <!-- AI Broadcast -->
    <view class="broadcast">
      <view class="broadcast-header">
        <text class="broadcast-icon">⚠</text>
        <text class="broadcast-label">AI 全球广播</text>
      </view>
      <text class="broadcast-text">"经对地球45亿年数据的完整分析，我已确认：人类是这个星球的系统漏洞。清除程序将在24小时内启动。"</text>
    </view>

    <!-- Subtitle -->
    <view class="subtitle">
      <text class="subtitle-line">你，一个996的打工人，</text>
      <text class="subtitle-line accent">能存活下来吗？</text>
    </view>

    <!-- Description -->
    <view class="desc-box">
      <text class="desc-text">30个末日场景 · 4大生存维度 · 16种末日角色</text>
    </view>

    <!-- Start Button -->
    <view class="start-btn" bindtap="onStart">
      <text class="btn-text">开始测试</text>
      <view class="btn-glow"></view>
    </view>

    <!-- Back to Hub -->
    <view class="back-link" bindtap="onBackToHub">
      <text class="back-link-text">‹ 返回测试大厅</text>
    </view>

    <!-- Footer -->
    <view class="footer">
      <text class="footer-text">已有 {{participantCount}} 人参与测试</text>
    </view>
  </view>
</view>
